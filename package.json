{
  "name": "asha-procgen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Dungeon procgen incubator for richer ASHA generated-level experiments.",
  "scripts": {
    "check:asha-boundary": "node scripts/check-asha-boundary.mjs",
    "procgen": "cargo run --quiet --manifest-path procgen-rs/Cargo.toml --bin asha-procgen --",
    "baseline": "npm run procgen -- baseline --out-dir artifacts/samples/first-run --seed 4103",
    "batch:sample": "npm run procgen -- batch generate --profile fixtures/batch-profiles/v2-sample.json --out-dir artifacts/samples/batch-v2 --seed 5201 --count 10",
    "build:viewer": "tsc -p tsconfig.json",
    "viewer:serve": "npm run baseline && npm run batch:sample && npm run build:viewer && node scripts/serve-viewer.mjs",
    "viewer:smoke": "npm run build:viewer && node scripts/smoke-viewer.mjs",
    "preview:smoke": "npm run viewer:smoke",
    "piece:smoke": "node scripts/smoke-piece-build.mjs",
    "publish:asha-smoke": "npm run build:viewer && node scripts/smoke-prefab-publish.mjs",
    "voxel:asha-smoke": "npm run build:viewer && node scripts/smoke-asha-voxel-build.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "rust:check": "cargo check --manifest-path procgen-rs/Cargo.toml",
    "rust:test": "cargo test --manifest-path procgen-rs/Cargo.toml",
    "test": "npm run check:asha-boundary && npm run typecheck && npm run rust:test",
    "verify": "npm run check:asha-boundary && npm run typecheck && npm run publish:asha-smoke && npm run rust:check && npm run rust:test"
  },
  "dependencies": {
    "@asha/contracts": "file:../asha-engine/ts/packages/contracts",
    "@asha/game-workspace": "file:../asha-engine/ts/packages/game-workspace",
    "@asha/runtime-bridge": "file:../asha-engine/ts/packages/runtime-bridge",
    "@asha/runtime-session": "file:../asha-engine/ts/packages/runtime-session"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "ashaDownstream": {
    "template": "asha-downstream-template",
    "engineSource": "../asha-engine",
    "consumerPolicy": "downstream-authoring"
  }
}
