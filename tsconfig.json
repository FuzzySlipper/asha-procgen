{
  "compilerOptions": {
    "allowJs": false,
    "declaration": true,
    "exactOptionalPropertyTypes": true,
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmitOnError": true,
    "outDir": "dist/ts",
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": ["src/**/*.ts", "viewer/**/*.ts"]
}
